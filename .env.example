# GEMINI_API_KEY (optional)
# AI features call Google Gemini. The recommended way to enable them is to enter
# your Gemini API key at runtime in Admin -> AI Tools (stored in your browser
# only). A key can also be injected at build/host time as a global named
# GEMINI_API_KEY for a private deployment.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- Firebase ----------------------------------------------------------------
# Client-side config is in src/environments/environment.ts (safe to commit).
# Firebase Admin SDK on Cloud Run uses default credentials automatically.
# For local server-side Firestore access, set GOOGLE_APPLICATION_CREDENTIALS
# to a service account key JSON path.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Stripe (Phase 2) -------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_BUSINESS=price_...

# --- Cloud Run / SSR runtime ------------------------------------------------
# PORT is provided by Cloud Run automatically (defaults to 8080). The SSR server
# also honours it for local runs.
# PORT=8080
#
# NG_ALLOWED_HOSTS controls Angular's SSR host-header (SSRF) check. Cloud Run
# terminates TLS and proxies traffic, so "*" is the default in the Docker image.
# Set this to your exact domain(s) (comma-separated) to enforce it in-app too.
# NG_ALLOWED_HOSTS=your-service-abc123-uc.a.run.app,www.example.com
