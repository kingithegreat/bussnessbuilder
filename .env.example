# GEMINI_API_KEY (optional)
# This app is a static SPA. The recommended way to enable AI is to enter your
# Gemini API key at runtime in Admin -> AI Tools (stored in your browser only).
#
# Optionally, a key can be injected at build/host time as a global named
# GEMINI_API_KEY for a private deployment. Note: any key embedded in a public
# static bundle is visible to visitors — only do this for trusted deployments.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
