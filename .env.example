# --- Firebase ----------------------------------------------------------------
# Client-side config is in src/environments/environment.ts (safe to commit).
# Firebase Admin SDK on Cloud Run uses default credentials automatically.
# For local server-side Firestore access, set GOOGLE_APPLICATION_CREDENTIALS
# to a service account key JSON path.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Stripe ------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_BUSINESS=price_...

# --- Admin panel ------------------------------------------------------------
# Comma-separated Firebase UIDs that can access /app-admin
# ADMIN_UIDS=your-firebase-uid

# --- SMTP (email notifications) ---------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@yourdomain.com

# --- Enquiry webhook ---------------------------------------------------------
# Optional. When set, each new enquiry submitted via POST /api/site/:uid/enquiry
# is fire-and-forget POSTed as JSON to this URL (event: "enquiry.created"),
# but ONLY for owners who have opted in to new-enquiry notifications
# (Admin -> Settings -> "Email me on new enquiry"). Use it to wire enquiries
# into Zapier, a CRM, Slack, etc. Delivery failures are logged, never block the
# enquiry response.
# ENQUIRY_WEBHOOK_URL=https://hooks.example.com/businessflow

# --- Gemini AI ---------------------------------------------------------------
# Used by the server-side /api/ai/generate endpoint. Falls back gracefully
# if not set. Users can also enter a key at runtime in Admin -> AI Tools.
# GEMINI_API_KEY=

# --- Cloud Run / SSR runtime ------------------------------------------------
# PORT is provided by Cloud Run automatically (defaults to 8080).
# PORT=8080
#
# NG_ALLOWED_HOSTS controls Angular's SSR host-header check. Set to "*" for
# Cloud Run or your exact domain(s) comma-separated.
# NG_ALLOWED_HOSTS=*
