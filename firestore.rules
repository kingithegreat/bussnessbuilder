rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Business data sub-docs: owner only for writes, public reads for published sites
      match /businessData/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Subscriptions: owner can read, only server (admin SDK) writes
    match /subscriptions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Slugs: public read for URL resolution, server-only writes
    match /slugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // Analytics: owner read/write for page view tracking
    match /analytics/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
