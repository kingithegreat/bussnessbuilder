{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "fallbackModel": ["claude-haiku-4-5"],
  "effortLevel": "high",
  "autoCompactEnabled": true,
  "fileCheckpointingEnabled": true,
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(npm run build)",
      "Bash(npm run test *)",
      "Bash(npm test *)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm install)",
      "Bash(pnpm install)",
      "Bash(pnpm run build)",
      "Bash(pnpm run test *)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run typecheck)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm run deploy)",
      "Bash(firebase deploy *)",
      "Bash(gcloud run deploy *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./serviceAccount*.json)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ]
  }
}
